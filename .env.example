# ── Conexión a la base de datos PostgreSQL ────────────────────────────────
# Copia este archivo como .env y completa los valores reales.
# El archivo .env nunca debe subirse al repositorio (ver .gitignore).

DB_USER=postgres
DB_PASSWORD=cambia_esta_clave
DB_NAME=balance_reportes
DB_HOST=localhost
DB_PORT=5432

# URL completa de conexión (usada directamente por la aplicación).
# Ajusta el host según el entorno:
#   - Desarrollo local : localhost
#   - Servidor/VPS     : IP o nombre de host del servidor de BD
DATABASE_URL=postgresql+psycopg2://postgres:cambia_esta_clave@localhost:5432/balance_reportes

# Ruta al archivo GeoJSON de sectores hidráulicos
SECTORES_GEOJSON=../assets/Sectores.geojson
